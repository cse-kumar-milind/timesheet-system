# ─── Copy this file to .env and fill in your values ────
# cp .env.example .env

# ─── Database Credentials ──────────────────────────────
MYSQL_ROOT_PASSWORD=your_mysql_password
DB_USERNAME=root

# ─── JWT Secret ────────────────────────────────────────
JWT_SECRET=your_jwt_secret_key_min_32_chars
JWT_EXPIRATION=86400000

# ─── Database URLs (Docker) ────────────────────────────
AUTH_DB_URL=jdbc:mysql://mysql-auth:3306/authdb?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true
TIMESHEET_DB_URL=jdbc:mysql://mysql-timesheet:3306/timesheet_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true
LEAVE_DB_URL=jdbc:mysql://mysql-leave:3306/leave_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true
ADMIN_DB_URL=jdbc:mysql://mysql-admin:3306/admin_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true

# ─── Eureka ────────────────────────────────────────────
EUREKA_URL=http://eureka-server:8761/eureka/

# ─── Zipkin (Distributed Tracing) ──────────────────────
ZIPKIN_URL=http://zipkin:9411/api/v2/spans

# ─── RabbitMQ ──────────────────────────────────────────
RABBITMQ_USER=admin
RABBITMQ_PASS=admin

# ─── Mail (SMTP) ───────────────────────────────────────
SPRING_MAIL_HOST=smtp.mailtrap.io
SPRING_MAIL_PORT=2525
SPRING_MAIL_USERNAME=your_username_here
SPRING_MAIL_PASSWORD=your_password_here
MAIL_FROM=noreply@timesheet.com
